---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SkillsCard from "../components/SkillsCard.astro";
import ServicesCard from "../components/ServicesCard.astro";
import projects from "../data/projects.js";
import skills from "../data/skills";
import services from "../data/services";
import ContactButton from "../components/ContactButton.astro";
import { Image } from "astro:assets";
import profilePhoto from "../images/profilePhoto.jpg";
import aboutPhoto from "../images/aboutPhoto.jpg";
---

<Layout
    title="Irina Kramer - Ecommerce & Technical Implementation Consultant, Web developer and designer"
>
    <!-- Hero -->
    <div class="relative isolate overflow-hidden py-24 sm:py-32">
        <img
            src="../background-amy-hirschi-unsplash.jpg"
            alt=""
            class="absolute inset-0 -z-10 size-full object-cover object-right opacity-10 md:object-center"
        />
        <div
            aria-hidden="true"
            class="hidden sm:absolute sm:-top-10 sm:right-1/2 sm:-z-10 sm:mr-10 sm:block sm:transform-gpu sm:blur-3xl"
        >
            <div
                style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"
                class="aspect-1097/845 w-274.25 bg-linear-to-tr from-[#ff4694] to-[#776fff] opacity-15"
            >
            </div>
        </div>
        <div
            aria-hidden="true"
            class="absolute -top-52 left-1/2 -z-10 -translate-x-1/2 transform-gpu blur-3xl sm:-top-112 sm:ml-16 sm:translate-x-0"
        >
            <div
                style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"
                class="aspect-1097/845 w-274.25 bg-linear-to-tr from-[#ff4694] to-[#776fff] opacity-15"
            >
            </div>
        </div>
        <div class="mx-auto max-w-6xl px-6 lg:px-8">
            <div class="mx-auto max-w-4xl lg:mx-0">
                <h2
                    class="text-6xl leading-12 font-display text-gray-900"
                >
                    Ecommerce & Technical Implementation Consultant
                </h2>
                <p
                    class="mt-8 text-lg open-sans text-pretty text-gray-700 sm:text-xl/8"
                >
                    Helping organizations implement and optimize
                    ecommerce and SaaS solutions. <br /><br />I
                    partner with businesses to streamline digital
                    operations, integrate platforms, solve technical
                    challenges, and improve customer and team
                    experiences—from implementation through ongoing
                    support.
                </p>
            </div>
            <div
                class="mx-auto mt-10 max-w-2xl lg:mx-0 lg:max-w-none"
            >
                <div
                    class="grid grid-cols-1 gap-x-8 gap-y-6 text-base/7 font-semibold text-gray-900 sm:grid-cols-2 md:flex lg:gap-x-10"
                >
                    <ContactButton text="Let's Connect" />
                </div>
            </div>
        </div>
    </div>

    <!-- services -->
    <div class="bg-white py-24 sm:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mx-auto max-w-2xl lg:text-center">
                <h2
                    class="text-base/7 font-semibold text-rose-600"
                    id="services"
                >
                    How I Can Help
                </h2>
                <p
                    class="mt-2 text-4xl font-display tracking-tight text-pretty text-gray-900 sm:text-5xl lg:text-balance"
                >
                    Services
                </p>
                <p class="mt-6 text-lg/8 text-gray-700">
                    I help businesses implement, integrate, and
                    optimize web and digital systems
                </p>
            </div>
            <div
                class="mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-4xl"
            >
                <dl
                    class="grid max-w-xl grid-cols-1 gap-x-8 gap-y-10 lg:max-w-none lg:grid-cols-2 lg:gap-y-16"
                >
                    <div class="relative pl-16">
                        <dt
                            class="text-base/7 font-semibold text-gray-900"
                        >
                            <div
                                class="absolute top-0 left-0 flex size-10 items-center justify-center rounded-lg bg-rose-600"
                            >
                                <svg
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.5"
                                    data-slot="icon"
                                    aria-hidden="true"
                                    class="size-6 text-white"
                                >
                                    <path
                                        d="M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    ></path>
                                </svg>
                            </div>
                            Ecommerce Implementation
                        </dt>
                        <dd class="mt-2 text-base/7 text-gray-600">
                            Ecommerce platform setup, product
                            taxonomy, catalog management, payment
                            providers, shipping, taxes, launch
                            support, documentation.
                        </dd>
                    </div>
                    <div class="relative pl-16">
                        <dt
                            class="text-base/7 font-semibold text-gray-900"
                        >
                            <div
                                class="absolute top-0 left-0 flex size-10 items-center justify-center rounded-lg bg-rose-600"
                            >
                                <svg
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.5"
                                    data-slot="icon"
                                    aria-hidden="true"
                                    class="size-6 text-white"
                                >
                                    <path
                                        d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    ></path>
                                </svg>
                            </div>
                            Systems Integration
                        </dt>
                        <dd class="mt-2 text-base/7 text-gray-600">
                            Event & workshops registration, product
                            reviews, web analytics, email
                            authentication, newsletters, UGC and app
                            integration.
                        </dd>
                    </div>
                    <div class="relative pl-16">
                        <dt
                            class="text-base/7 font-semibold text-gray-900"
                        >
                            <div
                                class="absolute top-0 left-0 flex size-10 items-center justify-center rounded-lg bg-rose-600"
                            >
                                <svg
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.5"
                                    data-slot="icon"
                                    aria-hidden="true"
                                    class="size-6 text-white"
                                >
                                    <path
                                        d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    ></path>
                                </svg>
                            </div>
                            Web design and development
                        </dt>
                        <dd class="mt-2 text-base/7 text-gray-600">
                            Web platform setup, UI/UX, branding,
                            content migration, page design and
                            building, user forms, website launch,
                            training & documentation.
                        </dd>
                    </div>
                    <div class="relative pl-16">
                        <dt
                            class="text-base/7 font-semibold text-gray-900"
                        >
                            <div
                                class="absolute top-0 left-0 flex size-10 items-center justify-center rounded-lg bg-rose-600"
                            >
                                <svg
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.5"
                                    data-slot="icon"
                                    aria-hidden="true"
                                    class="size-6 text-white"
                                >
                                    <path
                                        d="M7.864 4.243A7.5 7.5 0 0 1 19.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 0 0 4.5 10.5a7.464 7.464 0 0 1-1.15 3.993m1.989 3.559A11.209 11.209 0 0 0 8.25 10.5a3.75 3.75 0 1 1 7.5 0c0 .527-.021 1.049-.064 1.565M12 10.5a14.94 14.94 0 0 1-3.6 9.75m6.633-4.596a18.666 18.666 0 0 1-2.485 5.33"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    ></path>
                                </svg>
                            </div>
                            Web audits and technical troubleshooting
                        </dt>
                        <dd class="mt-2 text-base/7 text-gray-600">
                            Broken automations, tracking issues, email
                            problems, website issues, workflow
                            problems.
                        </dd>
                    </div>
                </dl>
            </div>
        </div>
    </div>

    <!-- portfolio -->
    <section>
        <div
            class="px-8 py-10 mx-auto text-center md:px-12 md:py-16 lg:px-24 lg:py-20 text-neutral-500 bg-white"
        >
            <div class="text-center">
                <h2
                    class="text-5xl font-display text-neutral-900 mb-8 lg:mb-12"
                    id="portfolio"
                >
                    Portfolio
                </h2>
            </div>
            <div
                class="grid grid-cols-1 gap-4 mx-auto text-sm font-medium lg:gap-8 sm:grid-cols-2 lg:grid-cols-2 max-w-7xl"
            >
                {
                    projects.map((project) => (
                        <ProjectCard
                            name={project.name}
                            url={project.url}
                            image={project.image.src}
                            tech={project.tech}
                            description={project.description}
                        />
                    ))
                }
            </div>
        </div>
    </section>

    <!-- testimonials -->
    <section id="testimonials" class="bg-white pt-12">
        <h2
            class="text-center text-base/7 font-semibold text-rose-600"
        >
            Testimonials
        </h2>
        <p
            class="mx-auto m-2 max-w-lg text-center text-4xl font-display tracking-tight text-balance text-gray-950 sm:text-5xl"
        >
            What my clients and colleagues are saying
        </p>

        <div
            class="relative isolate overflow-hidden bg-white px-6 py-24 sm:py-32 lg:px-8"
        >
            <div
                class="absolute inset-0 -z-10 bg-[radial-gradient(45rem_50rem_at_top,var(--color-indigo-100),white)] opacity-20"
            >
            </div>
            <div
                class="absolute inset-y-0 right-1/2 -z-10 mr-16 w-[200%] origin-bottom-left skew-x-[-30deg] bg-white ring-1 shadow-xl shadow-indigo-600/10 ring-indigo-50 sm:mr-28 lg:mr-0 xl:mr-16 xl:origin-center"
            >
            </div>
            <div class="mx-auto max-w-2xl lg:max-w-4xl">
                <!-- <img
                    class="mx-auto h-16"
                    src="https://fibercirclestudio.com/cdn/shop/products/1000x1000logo.jpg?v=1672540247&width=300"
                    alt=""
                /> -->
                <figure class="mt-10">
                    <blockquote
                        class="text-center text-xl/8 font-semibold text-gray-900 sm:text-2xl/9"
                    >
                        <p>
                            "I met Irina by chance at our local coffee
                            shop while she was working on a friend’s
                            website, and from that first conversation,
                            her enthusiasm and professionalism stood
                            out. She followed up promptly with a clear
                            and detailed email outlining what it would
                            look like to work with her—and from start
                            to finish, the process was a delight.
                            Irina is informed, up-to-date, and full of
                            joyful energy. Her communication was
                            always open and accessible, and her
                            innovative ideas helped shape a website
                            that is both engaging and truly reflective
                            of my work. She is skilled, efficient, and
                            a pleasure to collaborate with. I’m so
                            grateful to have found her."
                        </p>
                    </blockquote>
                    <figcaption class="mt-10">
                        <div
                            class="mt-4 flex items-center justify-center space-x-3 text-base"
                        >
                            <div class="font-semibold text-gray-900">
                                Jennifer Mygatt Tatum
                            </div>
                            <svg
                                viewBox="0 0 2 2"
                                width="3"
                                height="3"
                                aria-hidden="true"
                                class="fill-gray-900"
                            >
                                <circle cx="1" cy="1" r="1"></circle>
                            </svg>
                            <div class="text-gray-600">
                                Artist, creator
                            </div>
                        </div>
                    </figcaption>
                </figure>
            </div>
        </div>

        <div
            class="relative isolate overflow-hidden bg-white px-6 py-24 sm:py-32 lg:px-8"
        >
            <div
                class="absolute inset-0 -z-10 bg-[radial-gradient(45rem_50rem_at_top,var(--color-indigo-100),white)] opacity-20"
            >
            </div>
            <div
                class="absolute inset-y-0 right-1/2 -z-10 mr-16 w-[200%] origin-bottom-left skew-x-[-30deg] bg-white ring-1 shadow-xl shadow-indigo-600/10 ring-indigo-50 sm:mr-28 lg:mr-0 xl:mr-16 xl:origin-center"
            >
            </div>
            <div class="mx-auto max-w-2xl lg:max-w-4xl">
                <img
                    class="mx-auto h-16"
                    src="https://fibercirclestudio.com/cdn/shop/products/1000x1000logo.jpg?v=1672540247&width=300"
                    alt=""
                />
                <figure class="mt-10">
                    <blockquote
                        class="text-center text-xl/8 font-semibold text-gray-900 sm:text-2xl/9"
                    >
                        <p>
                            "Irina is great to work with! She is
                            knowledgeable, timely and very
                            communicative. If she doesn't have an
                            immediate answer, she will work to find
                            it, always keeping me in the loop. Highly
                            recommend her! You're amazing!! I keep
                            telling people how lucky I am to have you
                            helping with the website and all my misc
                            tech things!"
                        </p>
                    </blockquote>
                    <figcaption class="mt-10">
                        <div
                            class="mt-4 flex items-center justify-center space-x-3 text-base"
                        >
                            <div class="font-semibold text-gray-900">
                                Alisha Bright
                            </div>
                            <svg
                                viewBox="0 0 2 2"
                                width="3"
                                height="3"
                                aria-hidden="true"
                                class="fill-gray-900"
                            >
                                <circle cx="1" cy="1" r="1"></circle>
                            </svg>
                            <div class="text-gray-600">
                                Fiber Circle Studio, owner & creator
                            </div>
                        </div>
                    </figcaption>
                </figure>
            </div>
        </div>

        <div
            class="relative isolate overflow-hidden bg-white px-6 py-24 sm:py-32 lg:px-8"
        >
            <div
                class="absolute inset-0 -z-10 bg-[radial-gradient(45rem_50rem_at_top,var(--color-indigo-100),white)] opacity-20"
            >
            </div>
            <div
                class="absolute inset-y-0 right-1/2 -z-10 mr-16 w-[200%] origin-bottom-left skew-x-[-30deg] bg-white ring-1 shadow-xl shadow-indigo-600/10 ring-indigo-50 sm:mr-28 lg:mr-0 xl:mr-16 xl:origin-center"
            >
            </div>
            <div class="mx-auto max-w-2xl lg:max-w-4xl">
                <img
                    class="mx-auto h-10"
                    src="https://dianamajumdarart.com/wp-content/uploads/2024/08/Group-2-2.svg"
                    alt=""
                />
                <figure class="mt-10">
                    <blockquote
                        class="text-center text-xl/8 font-semibold text-gray-900 sm:text-2xl/9"
                    >
                        <p>
                            "I am beyond thrilled with my new website,
                            thanks to the incredible work of Irina
                            Kramer. I wanted something that truly
                            reflected my work as a fine art painter,
                            and Irina made it happen seamlessly. What
                            impressed me most was how much research
                            she did on her own. She explored artist
                            websites, picked out the best elements,
                            and came back with a fully developed
                            vision. From adding a short video of me
                            painting on the "About page" to designing
                            a layout that beautifully showcases my
                            work, to adding purchase options or
                            registering for a class, she thought of
                            everything. All I had to do was provide
                            access to my images — she handled the
                            rest. The result is a stunning,
                            professional site that feels like an
                            extension of my art. The site generated
                            several sales already! I can’t recommend
                            Irina highly enough!"
                        </p>
                    </blockquote>
                    <figcaption class="mt-10">
                        <div
                            class="mt-4 flex items-center justify-center space-x-3 text-base"
                        >
                            <div class="font-semibold text-gray-900">
                                Diana Majumdar
                            </div>
                            <svg
                                viewBox="0 0 2 2"
                                width="3"
                                height="3"
                                aria-hidden="true"
                                class="fill-gray-900"
                            >
                                <circle cx="1" cy="1" r="1"></circle>
                            </svg>
                            <div class="text-gray-600">
                                Fine Artist
                            </div>
                        </div>
                    </figcaption>
                </figure>
            </div>
        </div>

        <div
            class="relative isolate overflow-hidden bg-white px-6 py-24 sm:py-32 lg:px-8"
        >
            <div
                class="absolute inset-0 -z-10 bg-[radial-gradient(45rem_50rem_at_top,var(--color-indigo-100),white)] opacity-20"
            >
            </div>
            <div
                class="absolute inset-y-0 right-1/2 -z-10 mr-16 w-[200%] origin-bottom-left skew-x-[-30deg] bg-white ring-1 shadow-xl shadow-indigo-600/10 ring-indigo-50 sm:mr-28 lg:mr-0 xl:mr-16 xl:origin-center"
            >
            </div>
            <div class="mx-auto max-w-2xl lg:max-w-4xl">
                <img
                    class="mx-auto h-16"
                    src="https://getvectorlogo.com/wp-content/uploads/2018/10/lowepro-vector-logo.png"
                    alt=""
                />
                <figure class="mt-10">
                    <blockquote
                        class="text-center text-xl/8 font-semibold text-gray-900 sm:text-2xl/9"
                    >
                        <p>
                            "Irina is the type of professional
                            colleague everyone appreciates and
                            respects. Her combination of tech
                            knowledge, project management and positive
                            collaboration made our sites engaging,
                            clear, highly functional and relevant."
                        </p>
                    </blockquote>
                    <figcaption class="mt-10">
                        <div
                            class="mt-4 flex items-center justify-center space-x-3 text-base"
                        >
                            <div class="font-semibold text-gray-900">
                                Katrina Neill
                            </div>
                            <svg
                                viewBox="0 0 2 2"
                                width="3"
                                height="3"
                                aria-hidden="true"
                                class="fill-gray-900"
                            >
                                <circle cx="1" cy="1" r="1"></circle>
                            </svg>
                            <div class="text-gray-600">
                                Senior Copywriter
                            </div>
                        </div>
                    </figcaption>
                </figure>
            </div>
        </div>
    </section>

    <!-- skills -->
    <!-- <section>
        <div class="px-8 py-24 mx-auto md:px-12 lg:px-32 max-w-7xl">
            <div class="text-center">
                <h2
                    class="text-4xl noto-serif font-semibold tracking-tighter text-neutral-900 mb-8 lg:mb-12"
                    id="tech-stack"
                >
                    My Tech Stack
                </h2>
            </div>
            <div
                class="grid grid-cols-2 text-sm font-medium text-center text-neutral-500 gap-x-6 gap-y-12 lg:grid-cols-4 lg:gap-x-8 lg:gap-y-16 text-balance"
            >
                {
                    skills.map((skill) => (
                        <SkillsCard
                            name={skill.name}
                            description={skill.description}
                            logo={skill.logo}
                        />
                    ))
                }
            </div>
        </div>
    </section> -->

    <!-- services -->
    <!-- <section>
        <div class="relative">
            <div
                class="absolute top-0 z-[-2] h-full w-full rotate-180 transform bg-neutral-50 bg-[radial-gradient(40%_120%_at_50%_50%,hsla(0,0%,100%,0)_0,rgba(159,18,57,.2)_100%)]"
            >
            </div>

            <div
                class="px-8 py-24 mx-auto md:px-12 lg:px-32 max-w-7xl"
            >
                <div class="text-center">
                    <h2
                        class="text-4xl noto-serif font-semibold tracking-tighter text-neutral-900 mb-8 lg:mb-4"
                        id="services"
                    >
                        Web Services
                    </h2>
                    <p class="noto-serif text-neutral-500 mb-8">
                        I build and enhance custom ecommerce stores
                    </p>
                </div>
                <div
                    class="flex flex-wrap justify-center text-sm font-medium text-center text-neutral-500 gap-x-6 gap-y-12 lg:gap-x-8 lg:gap-y-16 text-balance"
                >
                    {
                        services.map((service) => (
                            <ServicesCard
                                name={service.name}
                                description={service.description}
                                icon={service.icon}
                            />
                        ))
                    }
                </div>
            </div>
        </div>
    </section> -->

    <!-- About -->
    <section id="about">
        <div
            class="relative isolate overflow-hidden bg-white px-6 py-24 sm:py-32 lg:overflow-visible lg:px-0"
        >
            <div class="absolute inset-0 -z-10 overflow-hidden">
                <svg
                    class="absolute top-0 left-[max(50%,25rem)] h-[64rem] w-[128rem] -translate-x-1/2 stroke-gray-200 [mask-image:radial-gradient(64rem_64rem_at_top,white,transparent)]"
                    aria-hidden="true"
                >
                    <defs>
                        <pattern
                            id="e813992c-7d03-4cc4-a2bd-151760b470a0"
                            width="200"
                            height="200"
                            x="50%"
                            y="-1"
                            patternUnits="userSpaceOnUse"
                        >
                            <path
                                d="M100 200V.5M.5 .5H200"
                                fill="none"></path>
                        </pattern>
                    </defs>
                    <svg
                        x="50%"
                        y="-1"
                        class="overflow-visible fill-gray-50"
                    >
                        <path
                            d="M-100.5 0h201v201h-201Z M699.5 0h201v201h-201Z M499.5 400h201v201h-201Z M-300.5 600h201v201h-201Z"
                            stroke-width="0"></path>
                    </svg>
                    <rect
                        width="100%"
                        height="100%"
                        stroke-width="0"
                        fill="url(#e813992c-7d03-4cc4-a2bd-151760b470a0)"
                    ></rect>
                </svg>
            </div>
            <div
                class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 lg:mx-0 lg:max-w-none lg:grid-cols-2 lg:items-start lg:gap-y-10"
            >
                <div
                    class="lg:col-span-2 lg:col-start-1 lg:row-start-1 lg:mx-auto lg:grid lg:w-full lg:max-w-7xl lg:grid-cols-2 lg:gap-x-8 lg:px-8"
                >
                    <div class="lg:pr-4">
